# Environment Variables Example
# Copy this file to .env and fill in your values

# Server Configuration
PORT=3000
NODE_ENV=production

# Database (Optional - for persistent chat history)
# MONGODB_URI=mongodb://localhost:27017/web-communication-app
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/web-communication-app

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_DIR=public/uploads

# CORS Configuration
CORS_ORIGIN=*

# Session Configuration (Optional)
# SESSION_SECRET=your-secret-key-here

# Redis Configuration (Optional - for scaling)
# REDIS_URL=redis://localhost:6379
# REDIS_URL=redis://username:password@host:port

# Email Configuration (Optional - for notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# Analytics (Optional)
# GOOGLE_ANALYTICS_ID=GA_MEASUREMENT_ID

# Logging
LOG_LEVEL=info
